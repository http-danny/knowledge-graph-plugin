{
  "name": "knowledge-graph",
  "version": "0.5.0",
  "description": "Read-only hybrid GraphRAG + code-intelligence over your local corpus, exposed as the kg MCP server.",
  "contextFileName": "GEMINI.md",
  "mcpServers": {
    "kg": {
      "command": "node",
      "args": [
        "${extensionPath}${/}bin${/}kg-hybrid-mcp.js"
      ],
      "cwd": "${workspacePath}",
      "env": {
        "KG_CONFIG_PATH": "${workspacePath}${/}kg.config.json",
        "KG_TOOL_PROFILE": "safe"
      }
    }
  }
}
